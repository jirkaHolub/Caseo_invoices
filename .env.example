# Zkopíruj do `.env` (lokálně) nebo nastav jako Environment Variables na Vercelu.
# .env je v .gitignore – NIKDY ho necommituj (obsahuje heslo k DB).

# --- Databáze ---
# Když je prázdné/nenastavené → použije se lokální SQLite (data.db).
# Pro Supabase vlož connection string:
#   Supabase → Project Settings → Database → Connection string → "URI"
# Pro serverless (Vercel) doporučeno použít "Connection pooling" (Transaction, port 6543).
# DATABASE_URL=postgresql://postgres.xxxx:HESLO@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# --- HTTP Basic auth (ochrana veřejné domény) ---
# Když jsou obě nastavené, web vyžaduje jméno+heslo. Když ne, je bez ochrany.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=zmen-toto-heslo
